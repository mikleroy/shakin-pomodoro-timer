{
  "manifest_version": 3,
  "name": "Shakin Pomodoro Timer",
  "version": "1.2.0",
  "description": "Pomodoro productivity timer with visual heatmap history, customizable cycle lengths, local-only storage. English & Russian.",
  "permissions": [
    "notifications",
    "alarms",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Pomodoro Timer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
